{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(cat */.env*)",
      "Bash(head */.env*)",
      "Bash(tail */.env*)",
      "Bash(less */.env*)",
      "Bash(more */.env*)",
      "Bash(source */.env*)",
      "Bash(printenv:*)",
      "Bash(env)",
      "Bash(env | *)",

      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",

      "Bash(zoom auth s2s set*)",
      "Bash(zoom auth s2s test*)",
      "Bash(zoom auth login*)",
      "Bash(zoom users me*)",
      "Bash(zoom users *)",
      "Bash(zoom meetings *)",
      "Bash(zoom recordings *)",
      "Bash(zoom phone *)",
      "Bash(zoom chat *)",
      "Bash(zoom reports *)",
      "Bash(zoom dashboard *)",
      "Bash(zoom webhook *)",

      "Bash(security find-generic-password*zoom-cli*)",
      "Bash(security find-generic-password*zoom-cli-auth*)",
      "Bash(security delete-generic-password*zoom-cli*)",
      "Bash(security delete-generic-password*zoom-cli-auth*)",
      "Bash(keyring get zoom-cli*)",
      "Bash(keyring get zoom-cli-auth*)",
      "Bash(keyring set zoom-cli*)",
      "Bash(keyring set zoom-cli-auth*)",

      "Bash(curl*api.zoom.us*)",
      "Bash(curl*zoom.us/oauth*)",
      "Bash(http*api.zoom.us*)",
      "Bash(httpie*api.zoom.us*)",
      "Bash(wget*api.zoom.us*)",

      "Read(./.zoom-cli/**)",
      "Read(~/.zoom-cli/**)",
      "Bash(cat ~/.zoom-cli/*)",
      "Bash(cat */.zoom-cli/*)",

      "Bash(npm publish*)",
      "Bash(yarn publish*)",
      "Bash(pip*upload*)",
      "Bash(twine upload*)",
      "Bash(python -m twine upload*)"
    ],
    "allow": [
      "Bash(git status*)",
      "Bash(git status:*)",
      "Bash(git log*)",
      "Bash(git log:*)",
      "Bash(git diff*)",
      "Bash(git diff:*)",
      "Bash(git show*)",
      "Bash(git show:*)",
      "Bash(git branch --list*)",
      "Bash(git branch -a*)",
      "Bash(git branch -vv*)",
      "Bash(git remote -v*)",
      "Bash(git remote show*)",
      "Bash(git tag --list*)",
      "Bash(git tag -l*)",
      "Bash(git stash list*)",
      "Bash(git worktree list*)",
      "Bash(git ls-files*)",
      "Bash(git ls-remote*)",
      "Bash(git config --get*)",
      "Bash(git config --list*)",
      "Bash(git rev-parse*)",
      "Bash(git describe*)",
      "Bash(git blame*)",

      "Bash(ruff check*)",
      "Bash(ruff format --check*)",
      "Bash(ruff format --diff*)",
      "Bash(mypy:*)",
      "Bash(mypy)",
      "Bash(pytest:*)",
      "Bash(pytest)",
      "Bash(python -m pytest:*)",
      "Bash(python -m pytest)",
      "Bash(python -m mypy:*)",
      "Bash(python -m ruff:*)",

      "Bash(pip show*)",
      "Bash(pip list*)",
      "Bash(pip index*)",
      "Bash(python -m pip show*)",
      "Bash(python -m pip list*)",
      "Bash(python --version)",
      "Bash(python3 --version)",

      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh repo view*)",
      "Bash(gh api repos/*)"
    ]
  }
}
